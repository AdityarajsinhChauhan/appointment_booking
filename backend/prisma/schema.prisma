generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model appointments {
  id          String             @id @default(uuid()) @db.Uuid
  user_id     String             @db.Uuid
  provider_id String             @db.Uuid
  slot_id     String             @db.Uuid
  status      String             @db.VarChar(20)
  created_at  DateTime           @default(now()) @db.Timestamp(6)
  providers   providers          @relation(fields: [provider_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users       users              @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  slot        availability_slots @relation(fields: [slot_id], references: [id])

  @@unique([slot_id, status])
}

model availability_slots {
  id           String         @id @default(uuid()) @db.Uuid
  provider_id  String         @db.Uuid
  start_time   DateTime       @db.Timestamp(6)
  end_time     DateTime       @db.Timestamp(6)
  is_booked    Boolean        @default(false)
  created_at   DateTime       @default(now()) @db.Timestamp(6)
  providers    providers      @relation(fields: [provider_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  appointments appointments[]
}

model providers {
  id                 String               @id @default(uuid()) @db.Uuid
  user_id            String               @unique @db.Uuid
  specialization     String               @db.VarChar(100)
  experience_years   Int
  rating             Float?               @default(0)
  total_reviews      Int?                 @default(0)
  address            String?              @db.VarChar(150)
  area               String?              @db.VarChar(150)
  city               String?              @db.VarChar(100)
  state              String?              @db.VarChar(100)
  pincode            String?              @db.VarChar(10)
  created_at         DateTime             @default(now()) @db.Timestamp(6)
  updated_at         DateTime             @default(now()) @db.Timestamp(6)
  appointments       appointments[]
  availability_slots availability_slots[]
  users              users                @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

enum Role {
  USER
  PROVIDER
  ADMIN
}

model users {
  id       String  @id @default(uuid()) @db.Uuid
  name     String  @db.VarChar(100)
  email    String  @unique @db.VarChar(150)
  password String
  contact  String? @db.VarChar(15)
  role     Role    @default(USER)
  img_url  String? @db.VarChar(100)

  refresh_token String? @unique

  created_at   DateTime       @default(now()) @db.Timestamp(6)
  updated_at   DateTime       @default(now()) @db.Timestamp(6)
  appointments appointments[]
  providers    providers?
}
